# ============================
# FRONTEND BUILD
# ============================
FROM node:24 AS frontend
WORKDIR /app/frontend

COPY frontend/package*.json ./
RUN npm install

COPY frontend/ .
RUN npm run build-prod

# ============================
# BACKEND BUILD
# ============================
FROM python:3.12-slim AS backend

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

# System deps for psycopg2
RUN apt-get update && apt-get install -y \
    build-essential \
    libpq-dev \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

# Install Python deps
COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy backend code
COPY backend/ .

###############################################
# COPY FRONTEND BUILD INTO DJANGO
###############################################

# Copy Vite assets → Django static root
COPY --from=frontend /app/frontend/dist/assets /app/static/assets

# Copy Vite index.html → Django template directory
COPY --from=frontend /app/frontend/dist/index.html /app/backend/RecipeSimply/templates/index.html

###############################################
# DJANGO COLLECTSTATIC
###############################################
RUN python manage.py collectstatic --noinput

###############################################
# START SERVER
###############################################
CMD ["gunicorn", "RecipeSimply.wsgi:application", "--bind", "0.0.0.0:8000"]
